# Secret compartilhado entre o Vercel e este proxy
# (mesmo valor deve estar na env var FACTA_PROXY_SECRET do Vercel)
FACTA_PROXY_SECRET=troque-aqui-por-uma-chave-longa-e-aleatoria

# Base da API FACTA
# Homologacao: https://webservice-homol.facta.com.br
# Producao:    https://webservice.facta.com.br
FACTA_BASE_URL=https://webservice.facta.com.br

# Porta local (nao precisa mudar)
PORT=3456
